# FILE: .env.example
# VERSION: 2.21.0
# ROLE: CONFIG
# MAP_MODE: SUMMARY
# START_MODULE_CONTRACT
#   PURPOSE: Document production environment variables and safe defaults for KrotPN.
#   SCOPE: Application, security, database, VPN, KPprotoN runtime bridge, Phase-36 Resend email, public domain, and Phase-35/37/38/41 edge configuration.
#   DEPENDS: M-001, M-012, M-044, M-046, M-048, M-050, M-052, M-053
#   LINKS: docs/modules/M-001.xml, docs/modules/M-044.xml, docs/modules/M-046.xml, docs/modules/M-048.xml, docs/modules/M-050.xml, docs/modules/M-052.xml, docs/modules/M-053.xml, docs/plans/Phase-35.xml, docs/plans/Phase-36.xml, docs/plans/Phase-38.xml, docs/plans/Phase-40.xml
# END_MODULE_CONTRACT
#
# START_MODULE_MAP
#   public-domain-tls-edge - FRONTEND_URL, DOMAIN, EDGE_TLS_*, MTPROTO_BASE_DOMAIN, and NGINX_CONF_PATH.
#   mtproto-runtime-bridge - MTPROTO_RUNTIME_POLICY_URL, MTPROTO_RUNTIME_TOKEN, private policy bind, and KPprotoN edge ports.
#   phase41-de-backed-edge - EDGE_MTPROTO_*, SNI_ROUTER_CONF_PATH, and DE KPprotoN target settings.
#   vpn-runtime - VPN and AmneziaWG host/runtime settings.
#   app-runtime - Backend, database, Redis, Resend email, billing, and referral settings.
# END_MODULE_MAP
#
# START_CHANGE_SUMMARY
#   LAST_CHANGE: v2.21.0 - Documented MTPROTO_AD_TAG zero-tag default for KPprotoN fake-TLS runtime.
#   LAST_CHANGE: v2.20.0 - Defaulted public 443 routing back to Phase-41 KPprotoN fake-TLS SNI split.
#   LAST_CHANGE: v2.19.0 - Defaulted public 443 routing to Phase-40 official MTProxy split.
#   LAST_CHANGE: v2.18.1 - Moved EDGE_HTTPS_FALLBACK_PORT default to private 9443 so 8443 remains public admin.
#   LAST_CHANGE: v2.18.0 - Documented Phase-38 DE-backed MTProto edge and RU SNI router variables.
#   LAST_CHANGE: v2.17.0 - Documented Phase-37 MTProto live runtime bridge and shared-443 defaults.
#   LAST_CHANGE: v2.16.0 - Documented Phase-36 Resend provider variables.
#   LAST_CHANGE: v2.15.0 - Added Phase-35 NGINX_CONF_PATH documentation for runtime nginx domain rendering.
# END_CHANGE_SUMMARY

# === APPLICATION ===
APP_NAME=KrotPN
APP_VERSION=2.8.2
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# === SECURITY ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-random-32-chars-string

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=change-this-to-fernet-key

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://krotvpn:password@db:5432/krotvpn

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === CORS ===
CORS_ORIGINS=["https://krotpn.xyz","https://www.krotpn.xyz"]

# === ADMIN ===
ADMIN_EMAIL=admin@krotpn.com
ADMIN_PASSWORD=SET_STRONG_UNIQUE_ADMIN_PASSWORD

# === VPN CONFIGURATION ===
VPN_SUBNET=172.29.0.0/22
VPN_CLIENT_SUBNET=172.29.0.0/22
VPN_CLIENT_GATEWAY=172.29.0.1
VPN_RELAY_SUBNET=172.29.255.0/30
VPN_RELAY_DE_ADDRESS=172.29.255.1
VPN_RELAY_RU_ADDRESS=172.29.255.2
VPN_CAPACITY_PROFILE=1000
VPN_NETWORK_ROTATE=false
VPN_PORT=51821
VPN_DNS=8.8.8.8, 1.1.1.1
VPN_MTU=1360
VPN_SERVER_PUBLIC_KEY=
VPN_SERVER_ENDPOINT=

# === AMNEZIAWG OBFUSCATION (DO NOT CHANGE!) ===
AWG_JC=120
AWG_JMIN=50
AWG_JMAX=1000
AWG_S1=111
AWG_S2=222
AWG_H1=1
AWG_H2=2
AWG_H3=3
AWG_H4=4

# === TRIAL ===
TRIAL_DAYS=3

# === YOOKASSA ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# === EMAIL ===
EMAIL_PROVIDER=disabled
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@krotpn.xyz

# === PUBLIC DOMAIN / TLS EDGE ===
FRONTEND_URL=https://krotpn.xyz
EMAIL_VERIFICATION_URL_BASE=https://krotpn.xyz/verify-email
MTPROTO_BASE_DOMAIN=krotpn.xyz
MTPROTO_PROXY_PORT=443
MTPROTO_BASE_SECRET_HEX=change-this-to-random-32-hex
MTPROTO_SECRET_SALT=change-this-to-random-32-hex
MTPROTO_AD_TAG=00000000000000000000000000000000
MTPROTO_RUNTIME_POLICY_URL=http://172.29.255.1:18080/krotpn/mtproto/policy
MTPROTO_RUNTIME_TOKEN=change-this-to-random-runtime-token
MTPROTO_RUNTIME_TIMEOUT_SECONDS=3.0
MTPROTO_POLICY_PORT=18080
MTPROTO_POLICY_BIND_IP=172.29.255.1
EDGE_PUBLIC_DOMAIN=krotpn.xyz
EDGE_CANONICAL_HOST=krotpn.xyz
EDGE_TLS_CERTIFICATE_PATH=/etc/nginx/ssl/server.crt
EDGE_TLS_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/server.key
EDGE_TLS_CERTIFICATE_MODE=operator-wildcard
EDGE_SHARED_443_ENABLED=true
EDGE_HTTPS_FALLBACK_PORT=9443
EDGE_MTPROTO_MODE=de-backed
EDGE_MTPROTO_DE_TARGET_HOST=203.0.113.10
EDGE_MTPROTO_DE_TARGET_PORT=443
NGINX_CONF_PATH=./nginx/nginx.runtime.conf
SNI_ROUTER_CONF_PATH=./deploy/haproxy-phase38.cfg

# === REFERRAL ===
REFERRAL_BONUS_DAYS=7
REFERRAL_MIN_PAYMENT=100.0
