# KrotVPN Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=KrotVPN
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
# SQLite for development
DATABASE_URL=sqlite+aiosqlite:///./krotvpn.db
# PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/krotvpn

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Data Encryption Key (for VPN private keys)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# CORS (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# VPN Configuration
VPN_SUBNET=10.10.0.0/24
VPN_PORT=51821
VPN_DNS=8.8.8.8, 1.1.1.1
VPN_MTU=1360

# AmneziaWG Obfuscation (MUST match server config)
AWG_JC=120
AWG_JMIN=50
AWG_JMAX=1000
AWG_S1=111
AWG_S2=222
AWG_H1=1
AWG_H2=2
AWG_H3=3
AWG_H4=4

# Trial
TRIAL_DAYS=3

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Tinkoff
TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# Referral
REFERRAL_BONUS_DAYS=7
REFERRAL_MIN_PAYMENT=100.0
