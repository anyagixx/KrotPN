# FILE: deploy/.env.example
# VERSION: 1.2.0
# START_MODULE_CONTRACT
#   PURPOSE: Canonical environment contract shared by install, Docker Compose, and Erlang runtime.
#   SCOPE: Domain, TLS, proxy secrets, data paths, image naming, and application ports.
#   DEPENDS: none
#   LINKS: M-CONFIG, M-DEPLOY, M-RELEASE
# END_MODULE_CONTRACT
#
# START_MODULE_MAP
#   BASE_DOMAIN - Public apex domain for the portal
#   RESEND_API_KEY - Resend bearer credential for email delivery
#   PROXY_SECRET_HEX - 32-character MTProto proxy base secret
#   PROXY_SECRET_SALT - Private salt used to derive per-SNI MTProto credentials
#   TLS_CERT_PATH - Fullchain certificate path inside mounted cert volume
#   TLS_KEY_PATH - Private key path inside mounted cert volume
#   DETS_DATA_DIR - Persistent DETS directory
#   RELEASE_NODE_NAME - Erlang node name
#   APP_IMAGE - Container image name
# END_MODULE_MAP
#
# START_CHANGE_SUMMARY
#   LAST_CHANGE: v1.2.0 - Added an operator-facing rollout warning that rotating the base secret or salt invalidates all issued tg://proxy links.
# END_CHANGE_SUMMARY

# START_BLOCK_PUBLIC_DOMAIN
BASE_DOMAIN=example.com
PORTAL_URL=https://example.com
PROXY_HOST=example.com
# END_BLOCK_PUBLIC_DOMAIN

# START_BLOCK_EMAIL_PROVIDER
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=KPprotoN <noreply@example.com>
# END_BLOCK_EMAIL_PROVIDER

# START_BLOCK_PROXY_RUNTIME
# Changing PROXY_SECRET_HEX or PROXY_SECRET_SALT invalidates all issued tg://proxy links; reissue every user link after rotation.
PROXY_SECRET_HEX=0123456789abcdef0123456789abcdef
PROXY_SECRET_SALT=abcdef0123456789abcdef0123456789
PROXY_PORT=443
PROXY_AD_TAG=ee000000000000000000000000000000
PROXY_LISTEN_IP=0.0.0.0
PORTAL_DOMAIN_FRONTING=127.0.0.1:8443
DOMAIN_FRONTING_TIMEOUT_SEC=10
CORE_API_HTTP_TIMEOUT_MS=10000
MAX_CONNECTIONS_PER_DOMAIN=100
MTPROXY_BOOT_RETRY_SECONDS=15
TOKEN_TTL_SECONDS=1800
# END_BLOCK_PROXY_RUNTIME

# START_BLOCK_TLS_PATHS
TLS_CERT_PATH=/certs/live/example.com/fullchain.pem
TLS_KEY_PATH=/certs/live/example.com/privkey.pem
TLS_WILDCARD_DOMAIN=*.example.com
TLS_CERTBOT_EMAIL=admin@example.com
# END_BLOCK_TLS_PATHS

# START_BLOCK_STORAGE
DETS_DATA_DIR=/var/lib/kpproton/dets
TOKEN_DATA_DIR=/var/lib/kpproton/tokens
CERTS_HOST_DIR=/etc/letsencrypt
DATA_HOST_DIR=./volumes/data
# END_BLOCK_STORAGE

# START_BLOCK_RELEASE
APP_IMAGE=kpproton:local
COMPOSE_PROJECT_NAME=kpproton
HOST_HTTPS_TARGET_PORT=443
RELEASE_NODE_NAME=kpproton@127.0.0.1
RELEASE_COOKIE=kpproton-cookie-change-me
ERLANG_DISTRIBUTION_PORT=4369
PORTAL_HTTP_INTERNAL_PORT=8080
PORTAL_TLS_INTERNAL_PORT=8443
# END_BLOCK_RELEASE
