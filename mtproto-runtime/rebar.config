%% FILE: rebar.config
%% VERSION: 1.0.0
%% START_MODULE_CONTRACT
%%   PURPOSE: Define the unified Erlang build graph, dependencies, source roots, and release assembly inputs.
%%   SCOPE: Compiler options, dependencies, source directories, and relx release wiring.
%%   DEPENDS: M-CONFIG
%%   LINKS: M-RELEASE
%% END_MODULE_CONTRACT
%%
%% START_MODULE_MAP
%%   erl_opts - compiler settings for the project
%%   deps - external runtime dependencies
%%   src_dirs - governed source roots for the unified build
%%   relx - release assembly configuration
%% END_MODULE_MAP
%%
%% START_CHANGE_SUMMARY
%%   LAST_CHANGE: v1.1.0 - Bumped the unified release version to 0.1.12-rc1 for the current test release push.
%% END_CHANGE_SUMMARY
%%
%% START_BLOCK_PROJECT_CONFIG
{erl_opts, [debug_info]}.

{deps, [
    {mtproto_proxy, {git, "https://github.com/seriyps/mtproto_proxy.git", {branch, "master"}}},
    {ranch, "2.2.0"},
    {cowboy, "2.12.0"},
    {jsx, "3.1.0"}
]}.

{src_dirs, [
    "src",
    "apps/kpproton_portal/src/http",
    "apps/kpproton_portal/src/token",
    "apps/kpproton_portal/src/integrations/resend",
    "apps/kpproton_proxy/src/registry",
    "apps/kpproton_proxy/src/provisioning",
    "apps/kpproton_proxy/src/mtproto"
]}.

{relx, [
    {release, {kpproton, "0.1.12-rc1"}, [kpproton, {mtproto_proxy, load}, sasl]},
    {dev_mode, false},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.
%% END_BLOCK_PROJECT_CONFIG
